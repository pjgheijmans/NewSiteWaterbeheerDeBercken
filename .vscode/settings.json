{
    // Jest-extensie (Orta.vscode-jest): toont teststatus in de Testing-zijbalk
    // en met groene/rode pictogrammen naast elke test in de editor.
    //
    // Twee "virtuele mappen" zodat zowel unit- als integratietests in het
    // Testing-paneel verschijnen, elk met een eigen run-gedrag:
    //   - "unit"        : draait via jest.config.js, watch-modus (live).
    //   - "integratie"  : draait via jest.integration.config.js, on-demand
    //                     (alleen wanneer je zelf op ▶ klikt) omdat deze een
    //                     bereikbare MySQL vereist (docker compose up -d db).
    "jest.virtualFolders": [
        {
            "name": "unit",
            "jestCommandLine": "npx jest --config jest.config.js",
            "runMode": "watch"
        },
        {
            "name": "integratie",
            "jestCommandLine": "npx jest --config jest.integration.config.js",
            "runMode": "on-demand"
        }
    ]
}
