{
    "name": "zwembad/dagstaat-php",
    "description": "PHP-backend (Slim 4 + PHP-DI) voor de Digitale Dagstaat Zwembad — port van de Node/Express-backend.",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-pdo": "*",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Zwembad\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
